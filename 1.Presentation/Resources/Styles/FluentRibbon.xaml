<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=mscorlib"
                    xmlns:options="http://schemas.microsoft.com/winfx/2006/xaml/presentation/options"
                    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                    xmlns:fluent="urn:fluent-ribbon"
                    xmlns:markups="clr-namespace:Common.WpfModule.Ui.Markups;assembly=Ui"
                    xmlns:local="clr-namespace:Common.WpfModule.Ui.AttachedProperties;assembly=Ui"
                    xmlns:converters="clr-namespace:Common.WpfModule.Ui.Converters;assembly=Ui"
                    mc:Ignorable="options d">
    
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/CommonResources;component/Styles/DefaultColorsAndBrushes.xaml" />
        <ResourceDictionary Source="/CommonResources;component/Styles/ComboBoxes.xaml" />
    </ResourceDictionary.MergedDictionaries>
    
    <!-- _______________ ШАБЛОНЫ _______________ -->
    
    <!-- Шаблон заголовка кнопки с увеличенным отступом слева перед текстом -->
    <DataTemplate x:Key="ButtonHeaderWithMarginLeft">
        <TextBlock Text="{Binding}" 
                   VerticalAlignment="Center"
                   TextWrapping="Wrap">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <!-- Базовый Margin -->
                    <Setter Property="Margin" Value="3,0,0,0"/>
                    <Style.Triggers>
                        <!-- Триггер, реагирующий на SizeDefinition кнопки -->
                        <DataTrigger Binding="{Binding SizeDefinition, 
                                            RelativeSource={RelativeSource AncestorType=fluent:Button}}"
                                     Value="Large">
                            <Setter Property="MaxWidth" Value="120" />
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="Padding" Value="0"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>
    </DataTemplate>

    <!-- _______________ ЦВЕТА, КИСТИ _______________ -->

    <!-- TODO: Синие акцентные цвета, возможно надо переместить в настройки Fluent-темы -->
    
    <SolidColorBrush x:Key="Fluent.Ribbon.Brushes.Highlight" 
                     Color="{StaticResource HighlightColor}" options:Freeze="True" />
    
    <SolidColorBrush x:Key="Fluent.Ribbon.Brushes.RibbonTabControl.Background" 
                     Color="{StaticResource HighlightColor}" options:Freeze="True" />
    <!--
    <SolidColorBrush x:Key="Fluent.Ribbon.Brushes.RibbonTabControl.TabsGrid.Background"
                     Color="{StaticResource HighlightColor}" options:Freeze="True" />
    -->
    <SolidColorBrush x:Key="Fluent.Ribbon.Brushes.RibbonWindow.TitleBackground" 
                     Color="{StaticResource HighlightColor}" options:Freeze="True" />
    <SolidColorBrush x:Key="Fluent.Ribbon.Brushes.AccentBase" 
                     Color="{StaticResource HighlightColor}" options:Freeze="True" />
    
    <!-- Меню (RibbonTabItem) -->
    <SolidColorBrush x:Key="Fluent.Ribbon.Brushes.RibbonTabItem.Foreground"
                     Color="{StaticResource DefaultDarkBackgroundColor}" options:Freeze="True" />
    <SolidColorBrush x:Key="Fluent.Ribbon.Brushes.RibbonTabItem.Selected.Foreground"
                     Color="{StaticResource DefaultBackgroundColor}" options:Freeze="True" />

    <!-- Backstage -->
    
    <SolidColorBrush x:Key="Fluent.Ribbon.Brushes.Backstage.Foreground" 
                     Color="{StaticResource DefaultDarkBackgroundColor}" options:Freeze="True" />
    <!-- <SolidColorBrush x:Key="Fluent.Ribbon.Brushes.Backstage.Background"  -->
    <!--                  Color="{StaticResource AccentColor}" options:Freeze="True" /> -->
    <!-- <SolidColorBrush x:Key="Fluent.Ribbon.Brushes.Backstage.BackButton.Background"  -->
    <!--                  Color="{StaticResource HighlightColor}" options:Freeze="True" /> -->
    <!-- <SolidColorBrush x:Key="Fluent.Ribbon.Brushes.Backstage.BackButton.Foreground"  -->
    <!--                  Color="{{Fluent.Ribbon.Brushes.Backstage.BackButton.Foreground}}" options:Freeze="True" /> -->
    <!-- <SolidColorBrush x:Key="Fluent.Ribbon.Brushes.BackstageTabControl.ItemsPanelBackground" -->
    <!--                  Color="{StaticResource Fluent.Ribbon.Colors.Accent80}" options:Freeze="True" /> -->
    
    <SolidColorBrush x:Key="Fluent.Ribbon.Brushes.BackstageTabControl.ItemsPanelBackground"
                     Color="{markups:Color BaseColor={StaticResource HighlightColor},
                     DeltaBrightness=0.1, DeltaSaturation=-0.4}" />
    <SolidColorBrush x:Key="Fluent.Ribbon.Brushes.BackstageTabItem.MouseOver.Background" 
                     Color="{markups:Color BaseColor={StaticResource HighlightColor}, 
                        DeltaBrightness=0.3, DeltaSaturation=-0.4, DeltaAlpha=-100}" options:Freeze="True" />
    
    <!-- Кнопки -->
    
    <SolidColorBrush x:Key="Fluent.Ribbon.Brushes.Button.MouseOver.Background" 
                     Color="{markups:Color BaseColor={StaticResource HighlightColor}, 
                        DeltaBrightness=0.3, DeltaSaturation=-0.4, DeltaAlpha=-100}" options:Freeze="True" />
    <SolidColorBrush x:Key="Fluent.Ribbon.Brushes.Button.MouseOver.Border" 
                     Color="{markups:Color BaseColor={StaticResource HighlightColor}, 
                        DeltaSaturation=-0.2, DeltaAlpha=-100}" options:Freeze="True" />
    <SolidColorBrush x:Key="Fluent.Ribbon.Brushes.Button.Pressed.Background" 
                     Color="{markups:Color BaseColor={StaticResource HighlightColor}, 
                        DeltaBrightness=0.2, DeltaSaturation=-0.2, DeltaAlpha=-100}" options:Freeze="True" />
    <SolidColorBrush x:Key="Fluent.Ribbon.Brushes.Button.Pressed.Border" 
                     Color="{markups:Color BaseColor={StaticResource HighlightColor}, 
                        DeltaBrightness=-0.1, DeltaSaturation=-0.2, DeltaAlpha=-100}" options:Freeze="True" />

    <!-- БАЗОВЫЙ СТИЛЬ ДЛЯ fluent:ComboBox -->
    <Style x:Key="BaseFluentComboBoxStyle" TargetType="fluent:ComboBox">
        <Setter Property="Width" Value="150" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Margin" Value="-4, 1, 0, 1" />
    </Style>

    <!-- СТИЛЬ-ПОТОМОК fluent:ComboBox, с логикой KeyValuePair, содержащей null -->
    <Style x:Key="FluentKeyValuePairComboBoxStyle" 
           TargetType="fluent:ComboBox"
           BasedOn="{StaticResource BaseFluentComboBoxStyle}">
        <Setter Property="DisplayMemberPath" Value="Value"/>
        <Setter Property="SelectedValuePath" Value="Key"/>
        <Setter Property="ItemContainerStyle" Value="{StaticResource KeyValuePairItemStyle}"/>
        <!-- Серый цвет поля ввода при выборе null -->
        <Style.Triggers>
            <DataTrigger Binding="{Binding SelectedValue, RelativeSource={RelativeSource Self}}" Value="{x:Null}">
                <Setter Property="Foreground" Value="{StaticResource LightGrayTextBrush}"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>
    
    <!-- _______________ ПОТОМКИ ЛЕНТЫ _______________ -->

    <Style TargetType="fluent:Ribbon">
        <Style.Resources>
            <!-- Стиль будет применяться ко всем элементам внутри этой группы -->
            
            <!-- Стиль для вкладок ленты -->
            <Style TargetType="fluent:RibbonTabItem">
                <!-- Убираем рамку фокуса -->
                <Setter Property="Focusable" Value="False"/>
            </Style>
            
            <!-- Кнопки -->
            <Style TargetType="fluent:Button">
                <!-- Делаем маленькую иконку + текст -->
                <Setter Property="SizeDefinition" Value="Middle" />
        
                <!-- Увеличиваем отступ текста от иконки -->
                <Setter Property="HeaderTemplate" Value="{StaticResource ButtonHeaderWithMarginLeft}"/>
            </Style>
    
            <!-- Комбобоксы (наследуют базовый стиль) -->
            <Style TargetType="fluent:ComboBox" 
                   BasedOn="{StaticResource BaseFluentComboBoxStyle}"/>
            
        </Style.Resources>
    </Style>

    <!-- _______________ ПОТОМКИ ЛЕНТЫ - ГРУППЫ И Т.П. _______________ -->
    
    <Style TargetType="fluent:RibbonGroupBox">
        <!-- Убираем сжатие группы -->
        <Setter Property="IsCollapsedHeaderContentPresenter" Value="False" />
        <Setter Property="State" Value="Large"/>
        
        <!-- Устанавливаем оптимальный padding -->
        <Setter Property="Padding" Value="5, 5, 6, 0"/>

        <Style.Resources>

            <!-- Стиль будет применяться ко всем TextBlock внутри этой группы -->
            <Style TargetType="TextBlock">
                <Setter Property="Margin" Value="2,0,0,0" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>
           
            <!-- Стиль будет применяться ко всем Label внутри этой группы -->
            <Style TargetType="Label">
                <Setter Property="Padding" Value="2,0,0,0" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>
            
            <!-- Стиль будет применяться ко всем RadioButton внутри этой группы -->
            <Style TargetType="fluent:RadioButton">
                <Setter Property="Margin" Value="0,0,-2,0" />
            </Style>
        </Style.Resources>
    </Style>
        
    <!-- Стиль для TabControl со скрытыми заголовками -->
    <Style x:Key="HiddenTabControlStyle" TargetType="TabControl">
        <Setter Property="Padding" Value="10 5 10 10" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabControl">
                    <Grid>
                        <ContentPresenter x:Name="PART_SelectedContentHost"
                                          ContentSource="SelectedContent"
                                          Margin="{TemplateBinding Padding}"
                                          SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        
        <!-- Скрываем заголовки TabItems -->
        <Setter Property="ItemContainerStyle">
            <Setter.Value>
                <Style TargetType="TabItem">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="0" />
                </Style>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Стиль для стандартного вертикального сепаратора в ленте -->
    <Style x:Key="Fluent.Ribbon.Styles.GroupBoxSeparator"
           TargetType="Separator" 
           BasedOn="{StaticResource Fluent.Ribbon.Styles.GroupBoxSeparator}">
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="Height" Value="Auto" />
        <Setter Property="Margin" Value="5, 0, 0, 0" /> 
    </Style>
    
    <!-- Стиль для вертикального сепаратора в ленте -->
    <Style x:Key="Fluent.Ribbon.Styles.VerticalGroupBoxSeparator"
           TargetType="Separator">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Separator">
                    <Border Background="{StaticResource Fluent.Ribbon.Brushes.Separator.Background}"
                            BorderBrush="{StaticResource Fluent.Ribbon.Brushes.Separator.Background}"
                            BorderThickness="1 0 0 0"
                            Margin="5 0 5 0"
                            Height="Auto"
                            VerticalAlignment="Stretch" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <!-- <Setter Property="Background" Value="{StaticResource Fluent.Ribbon.Brushes.Separator.Background}" /> -->
    </Style>
    
    <!-- Стиль для горизонтального сепаратора в ленте -->
    <Style x:Key="Fluent.Ribbon.Styles.HorizontalGroupBoxSeparator"
           TargetType="Separator" >
        <Setter Property="Height" Value="1" />
        <Setter Property="Background" Value="{StaticResource Fluent.Ribbon.Brushes.Separator.Background}" />
    </Style>
    
    <!-- Стиль для горизонтального сепаратора в Backstage -->
    <Style x:Key="HorizontalSeparatorTabItem" TargetType="fluent:SeparatorTabItem">
        <Setter Property="Height" Value="20" />
        <Setter Property="Margin" Value="12,0,12,0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="fluent:SeparatorTabItem">
                    <Rectangle
                        Height="1"
                        Fill="{StaticResource Fluent.Ribbon.Brushes.Button.MouseOver.Background}"
                        Margin="{TemplateBinding Margin}"
                        VerticalAlignment="Center" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- TODO: Временное решение: отображение в ToolTip ошибки валидации в представлении -->
    <Style TargetType="ComboBox">
        <Style.Triggers>
            <Trigger Property="Validation.HasError" Value="True">
                <Setter Property="ToolTip" 
                        Value="{Binding RelativeSource={RelativeSource Self}, 
                                    Path=(Validation.Errors)[0].ErrorContent}"/>
            </Trigger>
        </Style.Triggers>
    </Style>
    
    <!-- _______________ СТАТУС-БАР _______________ -->
    
    <Style TargetType="fluent:StatusBarItem">
        <!-- Общие отступы -->
        <Setter Property="Padding" Value="5, 0, 5, 0" />
        
        <Style.Triggers>
            <!-- Первый элемент -->
            <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, 
                                            Path=(local:ElementProperties.IsFirst)}" 
                         Value="True">
                <Setter Property="Padding" Value="10, 0, 5, 0"/>
            </DataTrigger>
            
            <!-- Последний элемент -->
            <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, 
                                            Path=(local:ElementProperties.IsLast)}" 
                         Value="True">
                <Setter Property="Padding" Value="0, 0, 10, 0"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>
    
</ResourceDictionary>