<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=mscorlib"
                    xmlns:options="http://schemas.microsoft.com/winfx/2006/xaml/presentation/options"
                    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                    xmlns:fluent="urn:fluent-ribbon"
                    xmlns:markup="clr-namespace:Common.WpfModule.Ui.Markup;assembly=Ui"
                    xmlns:converters="clr-namespace:Common.WpfModule.Ui.Converters;assembly=Ui"
                    mc:Ignorable="options d">
    
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/CommonResources;component/Styles/DefaultColorsAndBrushes.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <!-- TODO: Синие акцентные цвета, возможно надо переместить в настройки Fluent-темы -->
    <SolidColorBrush x:Key="Fluent.Ribbon.Brushes.RibbonTabControl.Background" 
                     Color="{StaticResource HighlightColor}" options:Freeze="True" />
    <!--
    <SolidColorBrush x:Key="Fluent.Ribbon.Brushes.RibbonTabControl.TabsGrid.Background"
                     Color="{StaticResource HighlightColor}" options:Freeze="True" />
    -->
    <SolidColorBrush x:Key="Fluent.Ribbon.Brushes.RibbonWindow.TitleBackground" 
                     Color="{StaticResource HighlightColor}" options:Freeze="True" />
    <SolidColorBrush x:Key="Fluent.Ribbon.Brushes.AccentBase" 
                     Color="{StaticResource HighlightColor}" options:Freeze="True" />
    
    <!-- Меню (RibbonTabItem) -->
    <SolidColorBrush x:Key="Fluent.Ribbon.Brushes.RibbonTabItem.Foreground"
                     Color="{StaticResource DefaultDarkBackgroundColor}" options:Freeze="True" />
    <SolidColorBrush x:Key="Fluent.Ribbon.Brushes.RibbonTabItem.Selected.Foreground"
                     Color="{StaticResource DefaultBackgroundColor}" options:Freeze="True" />

    <!-- Backstage -->
    <SolidColorBrush x:Key="Fluent.Ribbon.Brushes.Backstage.Foreground" 
                     Color="{StaticResource DefaultDarkBackgroundColor}" options:Freeze="True" />
    <!--
    <SolidColorBrush x:Key="Fluent.Ribbon.Brushes.Backstage.Background" 
                     Color="{StaticResource AccentColor}" options:Freeze="True" />
    -->
    <SolidColorBrush x:Key="Fluent.Ribbon.Brushes.BackstageTabControl.ItemsPanelBackground" 
                     Color="{StaticResource Fluent.Ribbon.Colors.Accent80}" options:Freeze="True" />
    <!--
    <SolidColorBrush x:Key="Fluent.Ribbon.Brushes.BackstageTabControl.ItemsPanelBackground" 
                     Color="{markup:Color BaseColor={StaticResource Fluent.Ribbon.Colors.AccentBase}, 
                     DeltaBrightness=0.05, DeltaSaturation=-0.2}" />
                     -->
    
    <Style TargetType="fluent:RibbonTabItem">
        <!-- Убираем рамку фокуса -->
        <Setter Property="Focusable" Value="False"/>
    </Style>
    
    <Style TargetType="fluent:RibbonGroupBox">
        <!-- Убираем сжатие группы -->
        <Setter Property="IsCollapsedHeaderContentPresenter" Value="False" />
        <Setter Property="State" Value="Large"/>
    </Style>
    
    <Style TargetType="fluent:Button">
        <!-- Делаем маленькую иконку + текст -->
        <Setter Property="SizeDefinition" Value="Middle" />
    </Style>
    
    <Style TargetType="fluent:ComboBox">
        <!-- Ширина комбобокса и отсутствие фокуса -->
        <Setter Property="Width" Value="120" />
        <Setter Property="Focusable" Value="False" />
    </Style>

    <!-- Статус-бар -->
    <Style TargetType="fluent:StatusBarItem">
        <!-- Общие отступы -->
        <Setter Property="Padding" Value="5, 0, 5, 0" />
        
        <Style.Triggers>
            <!-- Первый элемент -->
            <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" 
                         Value="First">
                <Setter Property="Padding" Value="10, 0, 5, 0"/>
            </DataTrigger>
            
            <!-- Последний элемент -->
            <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" 
                         Value="Last">
                <Setter Property="Padding" Value="0, 0, 10, 0"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>
</ResourceDictionary>