<!-- ШАБЛОНЫ И СТИЛИ МЕТОК -->

<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:Common.WpfModule.Ui.AttachedProperties;assembly=Ui">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/CommonResources;component/Styles/DefaultColorsAndBrushes.xaml" />
        <ResourceDictionary Source="/CommonResources;component/Styles/DefaultControl.xaml" />
    </ResourceDictionary.MergedDictionaries>
    
    <!-- _______________ БАЗОВАЯ МЕТКА (гориз. выравнивание по центру) _______________ -->
    <!-- Стиль -->
    <Style x:Key="BaseLabel" 
           TargetType="{x:Type Label}"
           BasedOn="{StaticResource DefaultControl}">
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Margin" Value="0  5 0 0" />
        <Setter Property="Padding" Value="0 0 2 2" /> 
        <Setter Property="Foreground" Value="{StaticResource DefaultForegroundBrush}" />
        <Style.Triggers>
            <!-- Видимость -->
            <Trigger Property="UIElement.IsEnabled" Value="false">
                <Setter Property="Control.Foreground" Value="{StaticResource DisabledForegroundBrush}"/>
            </Trigger>
            
            <!-- Первый элемент -->
            <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, 
                                            Path=(local:ElementProperties.IsFirst)}" 
                         Value="True">
                <Setter Property="Margin" Value="0"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>
    
    <!-- _______________ МЕТКА, ЖИРНЫЙ ТЕКСТ _______________ -->
    <!-- Стиль -->
    <Style x:Key="BaseLabel.Bold" 
           TargetType="{x:Type Label}"
           BasedOn="{StaticResource BaseLabel}">
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>

    <!-- _______________ МЕТКА, С ВЫРАВНИВАНИЕМ ПО ПРАВОМУ КРАЮ _______________ -->
    <!-- Стиль -->
    <Style x:Key="BaseLabel.ContentRight" 
           TargetType="{x:Type Label}"
           BasedOn="{StaticResource BaseLabel}">
        <Setter Property="HorizontalContentAlignment" Value="Right" />
    </Style>
    
    <!-- _______________ МЕТКА, С ВЫРАВНИВАНИЕМ ПО ЛЕВОМУ КРАЮ _______________ -->
    <!-- Стиль -->
    <Style x:Key="BaseLabel.ContentLeft" 
           TargetType="{x:Type Label}"
           BasedOn="{StaticResource BaseLabel}">
        <Setter Property="HorizontalContentAlignment" Value="Left" />
    </Style>
    
    <!-- _______________ МЕТКА, С ВЫРАВНИВАНИЕМ ПО ПРАВОМУ КРАЮ, ЖИРНЫЙ ШРИФТ _______________ -->
    <!-- Стиль -->
    <Style x:Key="BaseLabel.ContentRight.Bold" 
           TargetType="{x:Type Label}"
           BasedOn="{StaticResource BaseLabel.ContentRight}">
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>

    <!-- _______________ МЕТКА, С ВЫРАВНИВАНИЕМ ПО ЛЕВОМУ КРАЮ, ЖИРНЫЙ ШРИФТ _______________ -->
    <!-- Стиль -->
    <Style x:Key="BaseLabel.ContentLeft.Bold" 
           TargetType="{x:Type Label}"
           BasedOn="{StaticResource BaseLabel.ContentLeft}">
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>

</ResourceDictionary>
