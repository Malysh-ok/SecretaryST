<!-- СТИЛЬ КОНТРОЛА ПО УМОЛЧАНИЮ -->

<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=System.Runtime">
    
    <system:Int32 x:Key="DefaultMarginBetweenElements">7</system:Int32>
    
    <!-- Стиль -->
    <Style x:Key="DefaultControl" TargetType="{x:Type Control}">
        <Setter Property="FontFamily" Value="Segoe UI" />   <!-- По умолчанию - Segoe UI -->
        <Setter Property="FontSize" Value="12"/>
    </Style>
    
</ResourceDictionary>
