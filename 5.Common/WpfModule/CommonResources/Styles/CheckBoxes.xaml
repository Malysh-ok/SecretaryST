<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- _______________ БАЗОВЫЙ CheckBox _______________ -->
    <!-- Стиль -->
    <Style x:Key="BaseCheckBox" 
           TargetType="{x:Type CheckBox}">
        <!-- <Setter Property="Height" Value="26"/> -->
        <!-- <Setter Property="Padding" Value="3 0"/> -->
        <!-- <Setter Property="VerticalContentAlignment" Value="Center" /> -->
        <!-- <Setter Property="BorderThickness" Value="1" /> -->
        <!-- ~1~ <Setter Property="BorderBrush" Value="{StaticResource DefaultLightBorderBrush}"/> @1@ -->
        <!-- -->
        <!-- Для четкой границы -->
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
    </Style>
    
    <!-- _______________ CheckBox для внедрения в DataGrid _______________ -->
    <!-- Стиль -->
    <Style x:Key="CheckBoxForDataGrid"
           TargetType="{x:Type CheckBox}"
           BasedOn="{StaticResource BaseCheckBox}">
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
    </Style>


</ResourceDictionary>